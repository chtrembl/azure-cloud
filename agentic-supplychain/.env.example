# ─────────────────────────────────────────────────────────────
# Agentic Supply Chain – Environment Variables
# Copy this file to .env and fill in values before deploying.
# ─────────────────────────────────────────────────────────────

# ── Azure Identity / Subscription ──────────────────────────
# Azure subscription ID – find in Azure Portal → Subscriptions
AZURE_SUBSCRIPTION_ID=

# Entra ID tenant ID – find in Azure Portal → Microsoft Entra ID → Overview
AZURE_TENANT_ID=

# App registration (service principal) client ID for OIDC federation
# Create in Azure Portal → App Registrations; used by GitHub Actions
AZURE_CLIENT_ID=

# Azure region – must support Azure AI Foundry; default: eastus
AZURE_LOCATION=eastus

# ── Resource Group ─────────────────────────────────────────
# Name of the target resource group (created in Step 1)
RESOURCE_GROUP_NAME=agentic-supplychain

# ── Azure AI Foundry ──────────────────────────────────────
# Foundry account name – chosen during deployment
FOUNDRY_ACCOUNT_NAME=

# Foundry project name – created by Bicep deployment
FOUNDRY_PROJECT_NAME=agentic-supplychain-project

# Foundry project endpoint – from Bicep output or Azure Portal → Foundry project overview
AZURE_AI_PROJECT_ENDPOINT=

# Model deployment name (e.g., gpt-4o) – created in Step 3
MODEL_DEPLOYMENT_NAME=

# ── Azure AI Search ───────────────────────────────────────
# Search service name – from Bicep output or Azure Portal
SEARCH_SERVICE_NAME=

# Search service endpoint – https://<SEARCH_SERVICE_NAME>.search.windows.net
SEARCH_ENDPOINT=

# ── Azure Container Registry ─────────────────────────────
# ACR name – from Bicep output or Azure Portal
ACR_NAME=

# ── Monitoring ────────────────────────────────────────────
# Application Insights connection string – Azure Portal → App Insights → Properties
APPINSIGHTS_CONNECTION_STRING=

# ── Microsoft Fabric ──────────────────────────────────────
# Fabric workspace name – from Fabric Portal
FABRIC_WORKSPACE_NAME=

# Fabric data agent endpoint URL – from Fabric Portal → Data Agent settings
FABRIC_DATA_AGENT_ENDPOINT=

# ── Foundry IQ ────────────────────────────────────────────
# Foundry IQ MCP endpoint URL – from Foundry Portal → IQ → Connection details
FOUNDRY_IQ_MCP_URL=

# ── Agent Settings ────────────────────────────────────────
# Display name for the hosted agent
AGENT_NAME=orchestrator-agent
